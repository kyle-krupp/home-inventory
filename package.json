{
  "name": "home-inventory",
  "version": "0.0.0",
  "private": true,
  "description": "Home inventory monorepo",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "db:generate": "nx run database:generate",
    "db:migrate": "nx run database:migrate",
    "db:migrate:deploy": "nx run database:migrate-deploy",
    "db:seed": "nx run database:seed",
    "db:studio": "nx run database:studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "show-projects": "nx show projects"
  },
  "devDependencies": {
    "@nx/js": "22.7.5",
    "@prisma/client": "6.19.3",
    "@types/node": "^25.9.3",
    "csv-parse": "6.1.0",
    "nx": "22.7.5",
    "prisma": "6.19.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
