generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InventoryItem {
  id                    String    @id @default(uuid()) @db.Uuid
  room                  String?
  category              String?
  description           String
  brandModel            String?
  serialNumber          String?
  purchaseDate          DateTime? @db.Date
  purchaseLocation      String?
  originalCost          Decimal?  @db.Decimal(12, 2)
  estimatedCurrentValue Decimal?  @db.Decimal(12, 2)
  receiptPhotoFileName  String?
  condition             String?
  notes                 String?
  sourceFile            String
  sourceRow             Int
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([sourceFile, sourceRow])
  @@index([room])
  @@index([category])
  @@map("inventory_items")
}
